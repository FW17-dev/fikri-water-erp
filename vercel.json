{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ],
  "installCommand": "composer install --no-dev --optimize-autoloader --prefer-dist && npm install",
  "buildCommand": "php artisan config:clear && php artisan cache:clear && php artisan route:clear && php artisan view:clear && npm run build",
  "outputDirectory": "public"
}
