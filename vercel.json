{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "includeFiles": [
        "bootstrap/**",
        "config/**",
        "public/**",
        "resources/**",
        "routes/**",
        "storage/**",
        "vendor/**"
      ]
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ]
}
